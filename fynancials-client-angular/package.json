{
  "name": "fynancials",
  "private": true,
  "version": "1.0.1",
  "description": "Angular client for the Fynancials API",
  "author": "Armin Slopek",
  "license": "MIT",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/aslopek/fynancials"
  },
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "test": "echo \"no test specified\" && exit 0",
    "build": "npm run clean && npm run generate && ng build --base-href ./ && npm run licenses:generate",
    "licenses:generate": "node scripts/generate-third-party-licenses.js",
    "licenses:check": "node scripts/check-third-party-licenses.js",
    "clean": "npm run clean:dist && npm run clean:electron && npm run clean:gen",
    "clean:dist": "npx rimraf dist",
    "clean:electron": "npx rimraf out && npx rimraf resources",
    "clean:gen": "npx rimraf src/gen",
    "electron:start": "npx electron-forge start",
    "electron:pack": "npx electron-forge package && npx rimraf resources",
    "electron:make": "npx electron-forge make",
    "generate": "npx @openapitools/openapi-generator-cli generate",
    "serve": "npx @angular/cli serve",
    "watch": "ng build --watch --configuration development"
  },
  "devDependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/build": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@ngrx/component": "^21.0.1",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/signals": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@openapitools/openapi-generator-cli": "^2.13.9",
    "custom-electron-prompt": "^1.5.8",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "electron": "^43.0.0",
    "electron-squirrel-startup": "^1.0.0",
    "html2canvas-pro": "^2.0.2",
    "ngx-echarts": "^22.0.0",
    "rimraf": "^6.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript": "^6.0.3"
  }
}
